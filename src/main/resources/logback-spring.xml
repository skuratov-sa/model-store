<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- ================= Консоль ================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%X{traceId}] [%thread] %logger{36} - %msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <!-- ================= Файл (только prod) ================= -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/opt/logs/model-store-backend.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>/opt/logs/model-store-backend.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>14</maxHistory>
                <cleanHistoryOnStart>true</cleanHistoryOnStart>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp/>
                    <pattern>
                        <pattern>
                            {"level": "%level", "logger": "%logger", "message": "%message", "thread": "%thread", "traceId": "%X{traceId}"}
                        </pattern>
                    </pattern>
                    <mdc/>
                    <arguments/>
                    <message/>
                    <throwable/>
                </providers>
            </encoder>
        </appender>
    </springProfile>

    <!-- ================= Root ================= -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
    </root>

    <springProfile name="prod">
        <root level="DEBUG">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
</configuration>
